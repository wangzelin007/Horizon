{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "gpt-4o",
    "api_key_env": "GITHUB_TOKEN",
    "base_url": "https://models.inference.ai.azure.com",
    "temperature": 0.3,
    "max_tokens": 4096
  },
  "email": {
    "enabled": false,
    "smtp_server": "",
    "smtp_port": 465,
    "imap_server": "",
    "imap_port": 993,
    "email_address": "",
    "sender_name": "Horizon Daily",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "anthropics",
        "repo": "anthropic-cookbook",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "modelcontextprotocol",
        "repo": "specification",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "modelcontextprotocol",
        "repo": "servers",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "openai",
        "repo": "openai-agents-python",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "microsoft",
        "repo": "vscode",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "astral-sh",
        "repo": "uv",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 80
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "GitHub Blog",
        "url": "https://github.blog/feed/",
        "enabled": true,
        "category": "devtools"
      },
      {
        "name": "GitHub Changelog",
        "url": "https://github.blog/changelog/feed/",
        "enabled": true,
        "category": "devtools"
      },
      {
        "name": "Anthropic Research",
        "url": "https://www.anthropic.com/research/rss",
        "enabled": true,
        "category": "ai-agents"
      },
      {
        "name": "OpenAI Blog",
        "url": "https://openai.com/blog/rss.xml",
        "enabled": true,
        "category": "ai-models"
      },
      {
        "name": "The Pragmatic Engineer",
        "url": "https://newsletter.pragmaticengineer.com/feed",
        "enabled": true,
        "category": "engineering"
      },
      {
        "name": "Hugging Face Blog",
        "url": "https://huggingface.co/blog/feed.xml",
        "enabled": true,
        "category": "ai-ml"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        },
        {
          "subreddit": "ChatGPTCoding",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 30
        }
      ],
      "users": [],
      "fetch_comments": 5
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24
  }
}